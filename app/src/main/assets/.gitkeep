#!/usr/bin/env python3
"""
手机控制客户端 - Python 版
在 Termux 中运行
"""

import asyncio
import json
import os
import sys
import uuid
import argparse
from datetime import datetime

# 尝试导入 websockets
try:
    import websockets
except ImportError:
    print("请先安装: pip install websockets")
    sys.exit(1)


class PhoneControlClient:
    """手机控制客户端"""

    def __init__(self, server_url: str, device_name: str = None):
        self.device_id = str(uuid.uuid4())
        self.device_name = device_name or f"phone-{self.device_id[:8]}"
        self.server_url = server_url
        self.connected = False
        self.running = True

        # 获取设备信息
        self.device_info = self._gather_device_info()

    def _gather_device_info(self) -> dict:
        """收集设备信息"""
        info = {
            "name": self.device_name,
            "device_id": self.device_id,
            "capabilities": ["adb_shell", "screenshot", "uiauto"],
        }

        # 获取 Android 信息
        try:
            import subprocess
            result = subprocess.run(
                ["getprop", "ro.product.model"],
                capture_output=True, text=True, timeout=5
            )
            info["model"] = result.stdout.strip()

            result = subprocess.run(
                ["getprop", "ro.build.version.release"],
                capture_output=True, text=True, timeout=5
            )
            info["android_version"] = result.stdout.strip()
        except Exception:
            pass

        return info

    async def handle_command(self, action: str, params: dict) -> dict:
        """处理命令"""
        try:
            import subprocess

            if action == "adb_shell":
                cmd = params.get("command", "")
                result = subprocess.run(
                    ["adb"] + cmd.split(),
                    capture_output=True, text=True, timeout=30
                )
                return {
                    "success": result.returncode == 0,
                    "stdout": result.stdout,
                    "stderr": result.stderr,
                }

            elif action == "screenshot":
                # 截图
                local_path = "/sdcard/screen.png"
                subprocess.run(["screencap", "-p", local_path], timeout=10)

                # 读取并转 base64
                with open(local_path, "rb") as f:
                    import base64
                    img_data = base64.b64encode(f.read()).decode()

                return {"success": True, "image_base64": img_data}

            elif action == "ui_click":
                x, y = params.get("x", 0), params.get("y", 0)
                subprocess.run(["input", "tap", str(x), str(y)], timeout=5)
                return {"success": True}

            elif action == "ui_swipe":
                x1, y1 = params.get("x1", 0), params.get("y1", 0)
                x2, y2 = params.get("x2", 0), params.get("y2", 0)
                duration = params.get("duration_ms", 300)
                subprocess.run(
                    ["input", "swipe", str(x1), str(y1), str(x2), str(y2), str(duration)],
                    timeout=5
                )
                return {"success": True}

            elif action == "ui_input":
                text = params.get("text", "")
                subprocess.run(["input", "text", text.replace(" ", "%s")], timeout=5)
                return {"success": True}

            elif action == "press_key":
                keycode = params.get("keycode", 3)
                subprocess.run(["input", "keyevent", str(keycode)], timeout=5)
                return {"success": True}

            else:
                return {"success": False, "error": f"Unknown action: {action}"}

        except Exception as e:
            return {"success": False, "error": str(e)}

    async def connect(self):
        """连接到服务器"""
        ws_url = self.server_url.replace("http://", "ws://").replace("https://", "wss://")
        ws_url = f"{ws_url}/api/devices/ws/{self.device_id}"

        print(f"[*] 连接到: {ws_url}")
        print(f"[*] 设备ID: {self.device_id}")

        while self.running:
            try:
                async with websockets.connect(ws_url) as ws:
                    self.connected = True
                    print(f"[+] 连接成功")

                    # 发送设备信息
                    await ws.send(json.dumps({
                        "type": "register",
                        "device_id": self.device_id,
                        "device_info": self.device_info,
                    }))

                    # 保持连接并处理命令
                    while self.running:
                        try:
                            # 发送心跳
                            await ws.send(json.dumps({
                                "type": "heartbeat",
                                "device_id": self.device_id,
                                "timestamp": datetime.utcnow().isoformat(),
                            }))

                            # 接收命令
                            try:
                                data = await asyncio.wait_for(ws.recv(), timeout=30)
                                message = json.loads(data)

                                if message.get("type") == "command":
                                    cmd_id = message.get("cmd_id")
                                    action = message.get("action")
                                    params = message.get("params", {})

                                    print(f"[*] 执行命令: {action}")

                                    result = await self.handle_command(action, params)
                                    await ws.send(json.dumps({
                                        "type": "command_result",
                                        "cmd_id": cmd_id,
                                        "success": result.get("success", False),
                                        "output": result,
                                    }))

                                    print(f"[+] 命令完成: {action}")

                            except asyncio.TimeoutError:
                                continue

                        except websockets.exceptions.ConnectionClosed:
                            print("[-] 连接断开")
                            break

            except ConnectionRefusedError:
                print("[-] 连接被拒绝，等待重连...")
            except Exception as e:
                print(f"[-] 连接错误: {e}")

            self.connected = False
            await asyncio.sleep(5)

    def run(self):
        """运行客户端"""
        print("=" * 50)
        print("  手机控制客户端")
        print("=" * 50)
        asyncio.run(self.connect())

    def stop(self):
        """停止客户端"""
        self.running = False


def main():
    parser = argparse.ArgumentParser(description="手机控制客户端")
    parser.add_argument("--server", "-s", default="http://localhost:8000",
                        help="服务器地址")
    parser.add_argument("--name", "-n", default=None,
                        help="设备名称")
    args = parser.parse_args()

    client = PhoneControlClient(server_url=args.server, device_name=args.name)
    try:
        client.run()
    except KeyboardInterrupt:
        print("\n[*] 正在停止...")
        client.stop()


if __name__ == "__main__":
    main()
