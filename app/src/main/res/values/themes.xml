<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PhoneControl" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <style name="Widget.PhoneControl.Button" parent="Widget.Material3.Button">
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="Widget.PhoneControl.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="android:layout_marginBottom">8dp</item>
    </style>
</resources>
